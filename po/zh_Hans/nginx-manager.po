msgstr "HSTS max-age 时间（秒）。默认：31536000（1 年）。设为 0 禁用。"

msgid "HTTP/2"
msgstr "HTTP/2"

msgid "Enable HTTP/2 for SSL sites. Uses the http2 directive (nginx 1.25.1+)."
msgstr "为 SSL 站点启用 HTTP/2，使用 http2 指令（nginx 1.25.1+）。"

msgid "HTTP/3 (QUIC)"
msgstr "HTTP/3 (QUIC)"

msgid "Enable HTTP/3 over QUIC. Adds quic reuseport to listen directives and Alt-Svc header. Requires nginx built with QUIC support."
msgstr "启用基于 QUIC 的 HTTP/3，在 listen 指令中添加 quic reuseport 参数并输出 Alt-Svc 响应头。需要 nginx 编译时包含 QUIC 支持。"

msgid "SSL Session Tickets"
msgstr "SSL 会话票据"

msgid "Enable to improve TLS resumption performance, or disable for stricter forward secrecy."
msgstr "开启可提升 TLS 会话恢复性能，关闭可增强前向保密安全性。"
