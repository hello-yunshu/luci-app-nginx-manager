#!/bin/sh
# SPDX-License-Identifier: AGPL-3.0-only

START=80
USE_PROCD=1

PROG=/usr/sbin/nginx-manager-gen

validate_nginx_manager_global() {
    uci_validate_section nginx_manager global "${1}" \
        'managed_dir:string:/etc/nginx/conf.d/luci-manager' \
        'cert_dir:string:/etc/nginx/certs/luci-manager' \
        'backup_dir:string:/etc/nginx-manager/backups' \
        'auto_backup:bool:1' \
        'test_before_reload:bool:1' \
        'max_backups:uint:20' \
        'client_max_body_size:string:' \
        'keepalive_timeout:string:' \
        'gzip:bool:0' \
        'server_tokens:string:' \
        'sendfile:bool:0' \
        'access_log:string:' \
        'error_log:string:' \
        'ssl_protocols:string:' \
        'ssl_ciphers:string:' \
        'advanced_mode:bool:0' \
        'dangerous_core_edit:bool:0'
}

validate_nginx_manager_site() {
    uci_validate_section nginx_manager site "${1}" \
        'name:string' \
        'mode:string:reverse_proxy' \
        'server_name:string' \
        'enabled:bool:1' \
        'proxy_pass:string' \
        'root:string' \
        'index:string:index.html' \
        'websocket:bool:0' \
        'redirect_https:bool:0' \
        'proxy_host:bool:1' \
        'proxy_xff:bool:1' \
        'proxy_xfp:bool:1' \
        'proxy_xri:bool:1' \
        'ssl_cert:string' \
        'access_log:bool:0' \
        'error_log:bool:1' \
        'custom_server_block:string' \
        'redirect_target:string' \
        'listen:list(string)'
}

validate_nginx_manager_cert() {
    uci_validate_section nginx_manager cert "${1}" \
        'name:string' \
        'type:string:manual' \
        'cert_path:string' \
        'key_path:string' \
        'domain:string' \
        'auto_renew:bool:0'
}

start_service() {
    "${PROG}" generate >/dev/null 2>&1
}

stop_service() {
    return 0
}

reload_service() {
    "${PROG}" apply >/dev/null 2>&1
}

service_triggers() {
    procd_add_validation validate_nginx_manager_global
    procd_add_validation validate_nginx_manager_site
    procd_add_validation validate_nginx_manager_cert
    procd_add_reload_trigger "nginx_manager"
}

restart() {
    reload_service
}
