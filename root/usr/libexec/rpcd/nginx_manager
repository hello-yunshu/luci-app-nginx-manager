handle_list_certs() {
	load_global_config

	json_init
	json_add_array "certs"

	config_load nginx_manager
	config_foreach _list_cert cert

	json_close_array
	json_dump
}

_list_cert() {
	local section="$1"
	local name type cert_path key_path domain auto_renew

	name="$(uci -q get "nginx_manager.${section}.name")" || name="${section}"
	type="$(uci -q get "nginx_manager.${section}.type")" || type="manual"
	cert_path="$(uci -q get "nginx_manager.${section}.cert_path")" || cert_path=""
	key_path="$(uci -q get "nginx_manager.${section}.key_path")" || key_path=""
	domain="$(uci -q get "nginx_manager.${section}.domain")" || domain=""
	auto_renew="$(uci -q get "nginx_manager.${section}.auto_renew")" || auto_renew="0"

	json_add_object ""
	json_add_string "id" "${section}"
	json_add_string "name" "${name}"
	json_add_string "type" "${type}"
	json_add_string "cert_path" "${cert_path}"
	json_add_string "key_path" "${key_path}"
	json_add_string "domain" "${domain}"
	json_add_string "auto_renew" "${auto_renew}"

	local status="valid"
	if [ -n "${cert_path}" ] && [ ! -f "${cert_path}" ]; then
		status="missing"
	elif [ -n "${cert_path}" ] && [ -f "${cert_path}" ]; then
		local days
		days="$(get_cert_expiry "${cert_path}")" || days="-1"
		if [ "${days}" -lt 0 ]; then
			status="expired"
		elif [ "${days}" -lt 30 ]; then
			status="expiring"
		fi
	fi
	json_add_string "status" "${status}"

	json_close_object
}

