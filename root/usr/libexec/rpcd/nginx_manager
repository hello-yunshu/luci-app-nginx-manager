handle_get_logs() {
	local log_type lines filter site

	json_get_var log_type "type"
	json_get_var lines "lines"
	json_get_var filter "filter"
	json_get_var site "site"

	[ -z "${lines}" ] && lines="200"
	echo "${lines}" | grep -qE '^[0-9]+$' || lines="200"
	[ "${lines}" -gt 500 ] && lines="500"

	local log_paths log_path content found
	log_paths="$(resolve_log_paths "${log_type}" "${site}")" || {
		json_init
		json_add_string "error" "invalid log request"
		json_dump
		return
	}

	if [ -z "${log_paths}" ]; then
		json_init
		json_add_string "error" "log file not found"
		json_dump
		return
	fi

	content=""
	found="0"
	for log_path in ${log_paths}; do
		[ -f "${log_path}" ] || continue
		found="1"
		if [ -n "${content}" ]; then
			content="${content}
"
		fi
		content="${content}==> ${log_path} <=="
		if [ -n "${filter}" ]; then
			content="${content}
$(tail -n "${lines}" "${log_path}" | grep -F "${filter}" || true)"
		else
			content="${content}
$(tail -n "${lines}" "${log_path}")"
		fi
	done

	if [ "${found}" != "1" ]; then
		json_init
		json_add_string "error" "log file not found"
		json_dump
		return
	fi

	json_init
	json_add_string "content" "${content}"
	json_add_string "path" "${log_paths}"
	json_dump
}

resolve_log_paths() {
	local log_type="$1"
	local site="$2"
	local site_name log_path found

	if [ -n "${site}" ]; then
		validate_uci_id "${site}" || return 1
		site_name="$(uci -q get "nginx_manager.${site}.name")" || site_name="${site}"
		validate_name "${site_name}" || return 1
	fi

	case "${log_type}" in
		error)
			if [ -n "${site}" ]; then
				echo "/var/log/nginx/${site_name}.error.log"
			else
				found="0"
				for log_path in /var/log/nginx/error.log /var/log/nginx/*.error.log; do
					[ -f "${log_path}" ] || continue
					echo "${log_path}"
					found="1"
				done
				[ "${found}" = "1" ] || true
			fi
			;;
		access)
			if [ -n "${site}" ]; then
				echo "/var/log/nginx/${site_name}.access.log"
			else
				found="0"
				for log_path in /var/log/nginx/access.log /var/log/nginx/*.access.log; do
					[ -f "${log_path}" ] || continue
					echo "${log_path}"
					found="1"
				done
				[ "${found}" = "1" ] || true
			fi
			;;
		*)
			return 1
			;;
	esac
}

handle_clear_logs() {
	local log_type site log_paths log_path cleared

	json_get_var log_type "type"
	json_get_var site "site"

	log_paths="$(resolve_log_paths "${log_type}" "${site}")" || {
		json_init
		json_add_string "error" "invalid log request"
		json_dump
		return
	}

	if [ -z "${log_paths}" ]; then
		json_init
		json_add_string "error" "log file not found"
		json_dump
		return
	fi

	cleared="0"
	for log_path in ${log_paths}; do
		[ -f "${log_path}" ] || continue
		printf '' > "${log_path}" || {
			json_init
			json_add_string "error" "failed to clear log file"
			json_add_string "path" "${log_path}"
			json_dump
			return
		}
		cleared="1"
	done

	if [ "${cleared}" != "1" ]; then
		json_init
		json_add_string "error" "log file not found"
		json_dump
		return
	fi

	json_init
	json_add_string "result" "ok"
	json_add_string "path" "${log_paths}"
	json_dump
}

# Read a directive value from the effective nginx configuration (nginx -T)
# This covers all included files, not just the main config
_NGINX_T_CACHE=""
_read_nginx_directive() {
	local directive="$1"

	# Cache nginx -T output to avoid running it multiple times
	if [ -z "${_NGINX_T_CACHE}" ]; then
		detect_nginx_conf
		_NGINX_T_CACHE="$(nginx -T -c "${NGINX_CONF_PATH}" 2>/dev/null)" || _NGINX_T_CACHE=""
	fi

	local value=""
	if [ -n "${_NGINX_T_CACHE}" ]; then
		# Search for the directive in http{} top-level context only.
		# These directives appear with minimal indentation (0-4 spaces) inside http{},
		# while server{} and location{} directives have deeper indentation (8+ spaces).
		value="$(printf '%s\n' "${_NGINX_T_CACHE}" | \
			grep -E "^[[:space:]]{0,4}${directive}[[:space:]]+" | head -1 | \
			sed "s/.*${directive}[[:space:]]*//; s/[[:space:]]*;.*//")"
	fi

	# Fallback: search main config files if nginx -T didn't work
	if [ -z "${value}" ]; then
		local conf_files="/etc/nginx/uci.conf.template /etc/nginx/nginx.conf"
		for conf_file in ${conf_files}; do
			[ -f "${conf_file}" ] || continue
			value="$(grep -E "^[[:space:]]*${directive}[[:space:]]+" "${conf_file}" 2>/dev/null | head -1 | sed "s/.*${directive}[[:space:]]*//; s/[[:space:]]*;.*//")"
			[ -n "${value}" ] && break
		done
	fi

	echo "${value}"
}

handle_get_core_config() {
	load_global_config

	# Read nginx -T once for a fresh effective-config snapshot.
	detect_nginx_conf
	_NGINX_T_CACHE="$(nginx -T -c "${NGINX_CONF_PATH}" 2>/dev/null)" || _NGINX_T_CACHE="# nginx -T unavailable"

	local gzip_val sendfile_val server_tokens_val
	local max_body_val keepalive_val access_log_val error_log_val
	local ssl_session_timeout_val ssl_session_cache_val ssl_stapling_val ssl_buffer_size_val _val

	# Prefer the effective nginx configuration so the UI reflects what is
	# currently enabled after nginx has expanded its includes.
	_val="$(_read_nginx_directive client_max_body_size)"
	max_body_val="${_val}"
	_val="$(_read_nginx_directive keepalive_timeout)"
	keepalive_val="${_val}"
	_val="$(_read_nginx_directive gzip)"
	case "${_val}" in
		on) gzip_val="1" ;;
		off) gzip_val="0" ;;
		*) gzip_val="" ;;
	esac
	_val="$(_read_nginx_directive server_tokens)"
	case "${_val}" in
		on|off) server_tokens_val="${_val}" ;;
		*) server_tokens_val="" ;;
	esac
	_val="$(_read_nginx_directive sendfile)"
	case "${_val}" in
		on) sendfile_val="1" ;;
		off) sendfile_val="0" ;;
		*) sendfile_val="" ;;
	esac
	_val="$(_read_nginx_directive access_log)"
	access_log_val="${_val}"
	_val="$(_read_nginx_directive error_log)"
	error_log_val="${_val}"
	_val="$(_read_nginx_directive ssl_session_timeout)"
	ssl_session_timeout_val="${_val}"
	_val="$(_read_nginx_directive ssl_session_cache)"
	ssl_session_cache_val="${_val}"
	_val="$(_read_nginx_directive ssl_stapling)"
	case "${_val}" in
		on) ssl_stapling_val="1" ;;
		off) ssl_stapling_val="0" ;;
		*) ssl_stapling_val="" ;;
	esac
	_val="$(_read_nginx_directive ssl_buffer_size)"
	ssl_buffer_size_val="${_val}"

	# Fall back to UCI when nginx -T is unavailable or the directive is absent.
	[ -z "${max_body_val}" ] && max_body_val="$(uci -q get nginx_manager.global.client_max_body_size || true)"
	[ -z "${keepalive_val}" ] && keepalive_val="$(uci -q get nginx_manager.global.keepalive_timeout || true)"
	[ -z "${gzip_val}" ] && gzip_val="$(uci -q get nginx_manager.global.gzip || true)"
	[ -z "${server_tokens_val}" ] && server_tokens_val="$(uci -q get nginx_manager.global.server_tokens || true)"
	[ -z "${sendfile_val}" ] && sendfile_val="$(uci -q get nginx_manager.global.sendfile || true)"
	[ -z "${access_log_val}" ] && access_log_val="$(uci -q get nginx_manager.global.access_log || true)"
	[ -z "${error_log_val}" ] && error_log_val="$(uci -q get nginx_manager.global.error_log || true)"
	[ -z "${ssl_session_timeout_val}" ] && ssl_session_timeout_val="$(uci -q get nginx_manager.global.ssl_session_timeout || true)"
	[ -z "${ssl_session_cache_val}" ] && ssl_session_cache_val="$(uci -q get nginx_manager.global.ssl_session_cache || true)"
	[ -z "${ssl_stapling_val}" ] && ssl_stapling_val="$(uci -q get nginx_manager.global.ssl_stapling || true)"
	[ -z "${ssl_buffer_size_val}" ] && ssl_buffer_size_val="$(uci -q get nginx_manager.global.ssl_buffer_size || true)"

	json_init
	json_add_string "client_max_body_size" "${max_body_val}"
	json_add_string "keepalive_timeout" "${keepalive_val}"
	json_add_string "gzip" "${gzip_val}"
	json_add_string "server_tokens" "${server_tokens_val}"
	json_add_string "sendfile" "${sendfile_val}"
	json_add_string "access_log" "${access_log_val}"
	json_add_string "error_log" "${error_log_val}"
	json_add_string "ssl_session_timeout" "${ssl_session_timeout_val}"
	json_add_string "ssl_session_cache" "${ssl_session_cache_val}"
	json_add_string "ssl_stapling" "${ssl_stapling_val}"
	json_add_string "ssl_buffer_size" "${ssl_buffer_size_val}"
	json_add_string "custom_ssl_directives" "$(uci -q get nginx_manager.global.custom_ssl_directives || true)"
	json_add_string "advanced_mode" "$(uci -q get nginx_manager.global.advanced_mode || echo '0')"
	json_add_string "dangerous_core_edit" "$(uci -q get nginx_manager.global.dangerous_core_edit || echo '0')"
	json_dump
}

handle_sync_core_from_nginx() {
	local initialized
	initialized="$(uci -q get nginx_manager.global.core_config_initialized)" || initialized="0"

	if [ "${initialized}" = "1" ]; then
		json_init
		json_add_string "result" "ok"
		json_add_string "synced" "0"
		json_dump
		return
	fi

	load_global_config
	detect_nginx_conf
	_NGINX_T_CACHE="$(nginx -T -c "${NGINX_CONF_PATH}" 2>/dev/null)" || _NGINX_T_CACHE=""

	local nginx_val

	# Sync nginx directive values to UCI
	for field in client_max_body_size keepalive_timeout access_log error_log ssl_session_timeout ssl_session_cache ssl_buffer_size; do
		nginx_val="$(_read_nginx_directive "${field}")"
		if [ -n "${nginx_val}" ]; then
			uci set "nginx_manager.global.${field}=${nginx_val}"
		fi
	done

	# Handle boolean-like directives
	nginx_val="$(_read_nginx_directive "gzip")"
	case "${nginx_val}" in
		on)  uci set "nginx_manager.global.gzip=1" ;;
		off) uci set "nginx_manager.global.gzip=0" ;;
	esac

	nginx_val="$(_read_nginx_directive "sendfile")"
	case "${nginx_val}" in
		on)  uci set "nginx_manager.global.sendfile=1" ;;
		off) uci set "nginx_manager.global.sendfile=0" ;;
	esac

	nginx_val="$(_read_nginx_directive "tcp_nopush")"
	case "${nginx_val}" in
		on)  uci set "nginx_manager.global.tcp_nopush=1" ;;
		off) uci set "nginx_manager.global.tcp_nopush=0" ;;
	esac

	nginx_val="$(_read_nginx_directive "tcp_nodelay")"
	case "${nginx_val}" in
		on)  uci set "nginx_manager.global.tcp_nodelay=1" ;;
		off) uci set "nginx_manager.global.tcp_nodelay=0" ;;
	esac

	nginx_val="$(_read_nginx_directive "ssl_stapling")"
	case "${nginx_val}" in
		on)  uci set "nginx_manager.global.ssl_stapling=1" ;;
		off) uci set "nginx_manager.global.ssl_stapling=0" ;;
	esac

	# Handle server_tokens
	nginx_val="$(_read_nginx_directive "server_tokens")"
	case "${nginx_val}" in
		on|off) uci set "nginx_manager.global.server_tokens=${nginx_val}" ;;
	esac

	# Mark as initialized
	uci set "nginx_manager.global.core_config_initialized=1"
	uci commit nginx_manager

	json_init
	json_add_string "result" "ok"
	json_add_string "synced" "1"
	json_dump
}

