handle_get_file_readonly() {
	local file_path
	json_get_var file_path "path"
	[ -z "${file_path}" ] && { json_init; json_add_string "error" "missing path"; json_dump; return; }

	case "${file_path}" in
		/etc/nginx/uci.conf.template|/etc/nginx/nginx.conf|/etc/nginx/uci.conf)
			;;
		/etc/nginx/conf.d/luci-manager/*)
			;;
