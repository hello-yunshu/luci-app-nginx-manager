restore_nginx_tree_from_backup() {
	local backup_path="$1"

	[ -d "${backup_path}/nginx" ] || return 0
	mkdir -p /etc/nginx || return 1
	rm -rf /etc/nginx/*
	cp -a "${backup_path}/nginx/." /etc/nginx/
	return 0
}

restore_config_files_from_backup() {
	local backup_path="$1"
	local remove_missing="$2"

	if [ -f "${backup_path}/config-nginx" ]; then
		cp -a "${backup_path}/config-nginx" /etc/config/nginx
	elif [ "${remove_missing}" = "1" ]; then
		rm -f /etc/config/nginx
	fi

	if [ -f "${backup_path}/config-nginx-manager" ]; then
		cp -a "${backup_path}/config-nginx-manager" "${NGINX_MANAGER_CONFIG}"
	elif [ "${remove_missing}" = "1" ]; then
		rm -f "${NGINX_MANAGER_CONFIG}"
	fi

	return 0
}

handle_restore_backup() {
	local backup_id
	json_get_var backup_id "id"
	[ -z "${backup_id}" ] && { json_init; json_add_string "error" "missing id"; json_dump; return; }
	validate_backup_id "${backup_id}" || { json_init; json_add_string "error" "invalid id"; json_dump; return; }

	load_global_config
	detect_nginx_conf

	local backup_path="${BACKUP_DIR}/${backup_id}"
	[ -d "${backup_path}" ] || {
		json_init
		json_add_string "error" "backup not found"
		json_dump
		return
	}

	local timestamp
	timestamp="$(date '+%Y-%m-%d-%H%M%S')"
	local pre_restore_path="${BACKUP_DIR}/${timestamp}-pre-restore"
	mkdir -p "${pre_restore_path}/nginx"
	[ -d /etc/nginx ] && cp -a /etc/nginx/* "${pre_restore_path}/nginx/" 2>/dev/null
	[ -f /etc/config/nginx ] && cp -a /etc/config/nginx "${pre_restore_path}/config-nginx"
	[ -f "${NGINX_MANAGER_CONFIG}" ] && cp -a "${NGINX_MANAGER_CONFIG}" "${pre_restore_path}/config-nginx-manager"

	restore_nginx_tree_from_backup "${backup_path}" || {
		json_init
		json_add_string "error" "failed to restore nginx files"
		json_dump
		return
	}
	restore_config_files_from_backup "${backup_path}" "1"
	load_global_config
	detect_nginx_conf

	local generate_output
	generate_output="$("${NGINX_MANAGER_GEN}" generate 2>&1)"
	if [ $? -ne 0 ]; then
		restore_nginx_tree_from_backup "${pre_restore_path}"
		restore_config_files_from_backup "${pre_restore_path}" "1"
		load_global_config
		detect_nginx_conf
		nginx -t -c "${NGINX_CONF_PATH}" >/dev/null 2>&1
		/etc/init.d/nginx reload >/dev/null 2>&1

		json_init
		json_add_string "error" "generate failed after restore"
		json_add_string "detail" "${generate_output}"
		json_add_string "rolled_back" "1"
		json_dump
		return
	fi

	local test_output
	test_output="$(nginx -t -c "${NGINX_CONF_PATH}" 2>&1)"
	if [ $? -ne 0 ]; then
		restore_nginx_tree_from_backup "${pre_restore_path}"
		restore_config_files_from_backup "${pre_restore_path}" "1"
		load_global_config
		detect_nginx_conf
		nginx -t -c "${NGINX_CONF_PATH}" >/dev/null 2>&1
		/etc/init.d/nginx reload >/dev/null 2>&1

		json_init
		json_add_string "error" "nginx -t failed after restore"
		json_add_string "detail" "${test_output}"
		json_add_string "rolled_back" "1"
		json_dump
		return
	fi

	/etc/init.d/nginx reload >/dev/null 2>&1

	json_init
	json_add_string "result" "ok"
	json_dump
}

handle_diff_backup() {
