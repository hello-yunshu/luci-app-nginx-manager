			;;
		*)
			json_init
			json_add_string "error" "path not allowed"
			json_dump
			return
			;;
	esac

	if [ ! -f "${file_path}" ]; then
		json_init
		json_add_string "error" "file not found"
		json_dump
		return
	fi

	local content
