#!/bin/sh
# SPDX-License-Identifier: AGPL-3.0-only

. /usr/share/libubox/jshn.sh
. /lib/functions.sh

NGINX_MANAGER_CONFIG="/etc/config/nginx_manager"
MANAGED_DIR=""
CERT_DIR=""
BACKUP_DIR=""
NGINX_MANAGER_GEN="/usr/sbin/nginx-manager-gen"
NGINX_CONF_PATH=""
ACME_CHALLENGE_DIR="/var/run/acme/challenge"
ACME_RUN_TIMEOUT=900
ACME_RUN_POLL_INTERVAL=2

detect_nginx_conf() {
	[ -n "${NGINX_CONF_PATH}" ] && return
	if [ -f /etc/nginx/uci.conf ]; then
		NGINX_CONF_PATH="/etc/nginx/uci.conf"
	else
		NGINX_CONF_PATH="/etc/nginx/nginx.conf"
	fi
}

load_global_config() {
	MANAGED_DIR="$(uci -q get nginx_manager.global.managed_dir)" || MANAGED_DIR="/etc/nginx/conf.d/luci-manager"
	CERT_DIR="$(uci -q get nginx_manager.global.cert_dir)" || CERT_DIR="/etc/nginx/certs/luci-manager"
	BACKUP_DIR="$(uci -q get nginx_manager.global.backup_dir)" || BACKUP_DIR="/etc/nginx-manager/backups"
}

get_max_backups() {
	local max_backups
	max_backups="$(uci -q get nginx_manager.global.max_backups)" || max_backups="10"
	case "${max_backups}" in
		''|*[!0-9]*) max_backups="10" ;;
	esac
	[ "${max_backups}" -lt 1 ] && max_backups="1"
	printf '%s' "${max_backups}"
}

validate_name() {
	echo "$1" | grep -qE '^[a-zA-Z0-9_][a-zA-Z0-9._-]*$'
}

validate_uci_id() {
	echo "$1" | grep -qE '^[a-zA-Z0-9_]+$'
}

# Sanitize a user-provided ID for UCI section names:
# dots and hyphens are converted to underscores
sanitize_uci_id() {
	echo "$1" | sed 's/[^a-zA-Z0-9_]/_/g'
}

_RESOLVED_CERT_ID=""
_RESOLVE_CERT_ID_ERROR=""
resolve_new_cert_id() {
	local existing_type prefixed_id

	_RESOLVED_CERT_ID="$(sanitize_uci_id "$1")"
	_RESOLVE_CERT_ID_ERROR=""

	existing_type="$(uci -q get "nginx_manager.${_RESOLVED_CERT_ID}")" || existing_type=""
	[ -z "${existing_type}" ] && return 0

	if [ "${existing_type}" = "cert" ]; then
		_RESOLVE_CERT_ID_ERROR="certificate name conflicts with an existing certificate (resolved to ${_RESOLVED_CERT_ID})"
		return 1
	fi

	prefixed_id="cert_${_RESOLVED_CERT_ID}"
	existing_type="$(uci -q get "nginx_manager.${prefixed_id}")" || existing_type=""
	if [ -z "${existing_type}" ]; then
		_RESOLVED_CERT_ID="${prefixed_id}"
		return 0
	fi

	if [ "${existing_type}" = "cert" ]; then
		_RESOLVE_CERT_ID_ERROR="certificate name conflicts with an existing certificate (resolved to ${prefixed_id})"
	else
		_RESOLVE_CERT_ID_ERROR="name conflicts with an existing ${existing_type} (resolved to ${prefixed_id})"
	fi
	return 1
}

validate_backup_id() {
	echo "$1" | grep -qE '^20[0-9][0-9]-[0-9][0-9]-[0-9][0-9]-[0-9][0-9][0-9][0-9][0-9][0-9](-[A-Za-z0-9._-]+)?$'
}

validate_domain() {
	echo "$1" | grep -qE '^[a-zA-Z0-9._*-]+$'
}

validate_acme_dns_api() {
	echo "$1" | grep -qE '^dns_[A-Za-z0-9_]+$'
}

validate_acme_credential() {
	echo "$1" | grep -qE '^[A-Za-z_][A-Za-z0-9_]*=.+$'
}

validate_acme_account_email() {
	echo "$1" | grep -qE '^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z][A-Za-z]+$' || return 1
	echo "$1" | grep -qiE '@(example\.(com|net|org)|localhost)$' && return 1
	return 0
}

validate_positive_number() {
	echo "$1" | grep -qE '^[0-9]+$'
}

validate_nginx_time() {
	case "$1" in
		''|*[!0-9smhdwMy]*) return 1 ;;
	esac
	printf '%s' "$1" | grep -qE '^([0-9]+(ms|[smhdwMy])?)+$'
}

validate_proxy_timeout() {
	local field="$1"
	local value="$2"

	[ -z "${value}" ] && return 0
	validate_nginx_time "${value}" || {
		json_init
		json_add_string "error" "invalid ${field}"
		json_dump
		return 1
	}
	return 0
}

run_apply_or_error() {
	local apply_result
	apply_result="$("${NGINX_MANAGER_GEN}" apply 2>&1)"
	local apply_exit=$?

	if [ "${apply_exit}" -ne 0 ]; then
		json_init
		json_add_string "error" "apply failed"
		json_add_string "detail" "${apply_result}"
		json_dump
		return 1
	fi

	return 0
}

prepare_acme_challenge_config() {
	local cert_id="$1"
	local domain="$2"
	local challenge_conf test_output reload_output

	load_global_config

	mkdir -p "${ACME_CHALLENGE_DIR}" || {
		echo "failed to create ${ACME_CHALLENGE_DIR}"
		return 1
	}

	"${NGINX_MANAGER_GEN}" generate >/dev/null 2>&1 || {
		echo "failed to generate nginx manager config"
		return 1
	}

	mkdir -p "${MANAGED_DIR}/sites" || {
		echo "failed to create ${MANAGED_DIR}/sites"
		return 1
	}

	challenge_conf="${MANAGED_DIR}/sites/00-acme-challenge-${cert_id}.conf"
	cat > "${challenge_conf}" <<EOF
# Generated temporarily by luci-app-nginx-manager for ACME HTTP-01 validation.
server {
    listen 80;
    listen [::]:80;
    server_name ${domain};

    location ^~ /.well-known/acme-challenge/ {
        alias ${ACME_CHALLENGE_DIR}/;
        default_type text/plain;
    }

    location / {
        return 404;
    }
}
EOF

	detect_nginx_conf
	test_output="$(nginx -t -c "${NGINX_CONF_PATH}" 2>&1)" || {
		rm -f "${challenge_conf}"
		echo "${test_output}"
		return 1
	}

	reload_output="$(/etc/init.d/nginx reload 2>&1)" || {
		rm -f "${challenge_conf}"
		echo "${reload_output}"
		return 1
	}

	return 0
}

cleanup_acme_challenge_config() {
	local cert_id="$1"
	local challenge_conf

	load_global_config
	challenge_conf="${MANAGED_DIR}/sites/00-acme-challenge-${cert_id}.conf"
	rm -f "${challenge_conf}"

	detect_nginx_conf
	nginx -t -c "${NGINX_CONF_PATH}" >/dev/null 2>&1 && /etc/init.d/nginx reload >/dev/null 2>&1
}

get_cert_expiry() {
	local cert_path="$1"
	[ -f "${cert_path}" ] || return 1
	local end_date
	end_date="$(openssl x509 -enddate -noout -in "${cert_path}" 2>/dev/null | cut -d= -f2)"
	[ -z "${end_date}" ] && return 1

	# OpenSSL date format: "Sep  6 12:03:09 2026 GMT"
	# BusyBox date needs -D format spec; strip GMT and normalize double spaces
	local clean_date
	clean_date="$(echo "${end_date}" | sed 's/ GMT$//' | sed 's/  / /g')"

	local end_epoch now_epoch
	end_epoch="$(date -D "%b %d %H:%M:%S %Y" -d "${clean_date}" +%s 2>/dev/null)" || \
	end_epoch="$(date -d "${end_date}" +%s 2>/dev/null)" || \
	return 1

	now_epoch="$(date +%s)"
	echo "$(( (end_epoch - now_epoch) / 86400 ))"
}

handle_list_sites() {
	config_load nginx_manager

	json_init
	json_add_array "sites"

	config_foreach _list_site site

	json_close_array
	json_dump
}

_list_site() {
	local section="$1"
	local name mode server_name enabled ssl_cert

	name="$(uci -q get "nginx_manager.${section}.name")" || name="${section}"
	mode="$(uci -q get "nginx_manager.${section}.mode")" || mode="reverse_proxy"
	server_name="$(uci -q get "nginx_manager.${section}.server_name")" || server_name=""
	enabled="$(uci -q get "nginx_manager.${section}.enabled")" || enabled="1"
	ssl_cert="$(uci -q get "nginx_manager.${section}.ssl_cert")" || ssl_cert=""

	json_add_object ""
	json_add_string "id" "${section}"
	json_add_string "name" "${name}"
	json_add_string "mode" "${mode}"
	json_add_string "server_name" "${server_name}"
	json_add_string "enabled" "${enabled}"
	json_add_string "ssl_cert" "${ssl_cert}"

	if [ "${mode}" = "reverse_proxy" ]; then
		local proxy_pass
		proxy_pass="$(uci -q get "nginx_manager.${section}.proxy_pass")" || proxy_pass=""
		json_add_string "proxy_pass" "${proxy_pass}"
	elif [ "${mode}" = "static" ]; then
		local root
		root="$(uci -q get "nginx_manager.${section}.root")" || root=""
		json_add_string "root" "${root}"
	fi

	local has_ssl="0"
	if [ -n "${ssl_cert}" ]; then
		has_ssl="1"
	fi
	json_add_string "has_ssl" "${has_ssl}"

	json_close_object
}

handle_get_site() {
	local site_id
	json_get_var site_id "id"
	[ -z "${site_id}" ] && { json_init; json_add_string "error" "missing id"; json_dump; return; }
	validate_uci_id "${site_id}" || { json_init; json_add_string "error" "invalid id"; json_dump; return; }

	config_load nginx_manager

	local exists
	exists="$(uci -q get "nginx_manager.${site_id}")" || {
		json_init
		json_add_string "error" "site not found"
		json_dump
		return
	}

	json_init
	json_add_string "id" "${site_id}"

	local opt
	for opt in name mode server_name listen_addr listen_port proxy_pass root index websocket proxy_type grpc_path grpc_pass custom_proxy_headers redirect_https redirect_http_port \
		proxy_host proxy_xff proxy_xfp proxy_xri ssl_cert ssl_protocols ssl_ciphers hsts_max_age \
		access_log error_log \
		custom_server_block redirect_target enabled \
		proxy_connect_timeout proxy_read_timeout proxy_send_timeout; do
		local val
		val="$(uci -q get "nginx_manager.${site_id}.${opt}")" || continue
		json_add_string "${opt}" "${val}"
	done

	# Backward compatibility: migrate old listen list to listen_addr/listen_port
	local listen_addr_exists listen_port_exists
	listen_addr_exists="$(uci -q get "nginx_manager.${site_id}.listen_addr")"
	listen_port_exists="$(uci -q get "nginx_manager.${site_id}.listen_port")"

	if [ -z "${listen_addr_exists}" ] && [ -z "${listen_port_exists}" ]; then
		# No new fields, check for old listen list
		local listen_vals="" listen_found="0"
		config_list_foreach "${site_id}" listen _collect_listen
		if [ "${listen_found}" = "1" ]; then
			# Parse first listen value to extract addr and port
			local first_listen="${listen_vals%%,*}"
			local addr="" port=""
			case "${first_listen}" in
				*:*)
					addr="${first_listen%:*}"
					port="${first_listen##*:}"
					;;
				*)
					port="${first_listen}"
					;;
			esac
			# Strip ssl and other options from port
			port="$(echo "${port}" | sed 's/ .*//')"
			json_add_string "listen_addr" "${addr}"
			json_add_string "listen_port" "${port}"
		fi
	fi

	json_dump
}

_collect_listen() {
	if [ "${listen_found}" = "1" ]; then
		listen_vals="${listen_vals},$1"
	else
		listen_vals="$1"
		listen_found="1"
	fi
}

handle_set_site() {
	local site_id name mode server_name proxy_pass root index
	local websocket proxy_type custom_proxy_headers redirect_https redirect_http_port proxy_host proxy_xff proxy_xfp proxy_xri
	local ssl_cert ssl_protocols ssl_ciphers hsts_max_age access_log error_log custom_server_block redirect_target enabled
	local listen_addr listen_port grpc_path grpc_pass
	local proxy_connect_timeout proxy_read_timeout proxy_send_timeout

	json_get_var site_id "id"
	json_get_var name "name"
	json_get_var mode "mode"
	json_get_var server_name "server_name"
	json_get_var listen_addr "listen_addr"
	json_get_var listen_port "listen_port"
	json_get_var proxy_pass "proxy_pass"
	json_get_var root "root"
	json_get_var index "index"
	json_get_var websocket "websocket"
	json_get_var proxy_type "proxy_type"
	json_get_var grpc_path "grpc_path"
	json_get_var grpc_pass "grpc_pass"
	json_get_var custom_proxy_headers "custom_proxy_headers"
	json_get_var redirect_https "redirect_https"
	json_get_var redirect_http_port "redirect_http_port"
	json_get_var proxy_host "proxy_host"
	json_get_var proxy_xff "proxy_xff"
	json_get_var proxy_xfp "proxy_xfp"
	json_get_var proxy_xri "proxy_xri"
	json_get_var ssl_cert "ssl_cert"
	json_get_var ssl_protocols "ssl_protocols"
	json_get_var ssl_ciphers "ssl_ciphers"
	json_get_var hsts_max_age "hsts_max_age"
	json_get_var access_log "access_log"
	json_get_var error_log "error_log"
	json_get_var custom_server_block "custom_server_block"
	json_get_var redirect_target "redirect_target"
	json_get_var enabled "enabled"
	json_get_var proxy_connect_timeout "proxy_connect_timeout"
	json_get_var proxy_read_timeout "proxy_read_timeout"
	json_get_var proxy_send_timeout "proxy_send_timeout"

	[ -z "${site_id}" ] && { json_init; json_add_string "error" "missing id"; json_dump; return; }
	validate_uci_id "${site_id}" || { json_init; json_add_string "error" "invalid site id"; json_dump; return; }
	[ -z "${name}" ] && name="${site_id}"
	validate_name "${name}" || { json_init; json_add_string "error" "invalid name"; json_dump; return; }

	case "${mode}" in
		reverse_proxy|static|custom|redirect|"") ;;
		*) { json_init; json_add_string "error" "invalid mode"; json_dump; return; } ;;
	esac

	if [ -n "${server_name}" ]; then
		validate_domain "${server_name}" || { json_init; json_add_string "error" "invalid server_name"; json_dump; return; }
	fi

	case "${proxy_type}" in
		http|grpc|websocket|"") ;;
		*) { json_init; json_add_string "error" "invalid proxy_type"; json_dump; return; } ;;
	esac

	# gRPC passthrough validation: grpc_path must be a single safe nginx location prefix.
	if [ -n "${grpc_path}" ]; then
		[ "${grpc_path}" != "/" ] || { json_init; json_add_string "error" "grpc_path must be more specific than /"; json_dump; return; }
		printf '%s\n' "${grpc_path}" | grep -qE '^/[A-Za-z0-9._~!$&()*+,;=:@%/-]+$' || {
			json_init; json_add_string "error" "invalid grpc_path"; json_dump; return;
		}
	fi

	# gRPC passthrough validation: grpc_pass must use grpc:// or grpcs:// if provided
	if [ -n "${grpc_pass}" ]; then
		case "${grpc_pass}" in
			grpc://*|grpcs://*) ;;
			*) { json_init; json_add_string "error" "invalid grpc_pass, must use grpc:// or grpcs://"; json_dump; return; } ;;
		esac
	fi

	# gRPC passthrough requires both grpc_path and grpc_pass
	if [ -n "${grpc_path}" ] && [ -z "${grpc_pass}" ]; then
		{ json_init; json_add_string "error" "grpc_pass is required when grpc_path is set"; json_dump; return; }
	fi
	if [ -n "${grpc_pass}" ] && [ -z "${grpc_path}" ]; then
		{ json_init; json_add_string "error" "grpc_path is required when grpc_pass is set"; json_dump; return; }
	fi

	if [ "${mode}" = "reverse_proxy" ] && [ -n "${proxy_pass}" ]; then
		case "${proxy_pass}" in
			http://*|https://*|unix:*|grpc://*|grpcs://*) ;;
			*) { json_init; json_add_string "error" "invalid proxy_pass"; json_dump; return; } ;;
		esac
	fi

	validate_proxy_timeout "proxy_connect_timeout" "${proxy_connect_timeout}" || return
	validate_proxy_timeout "proxy_read_timeout" "${proxy_read_timeout}" || return
	validate_proxy_timeout "proxy_send_timeout" "${proxy_send_timeout}" || return

	if [ -n "${root}" ]; then
		case "${root}" in
			/www/*) ;;
			*) { json_init; json_add_string "error" "invalid root path"; json_dump; return; } ;;
		esac
	fi

	if [ -n "${redirect_target}" ]; then
		case "${redirect_target}" in
			http://*|https://*|//$*) ;;
			*) { json_init; json_add_string "error" "invalid redirect_target"; json_dump; return; } ;;
		esac
	fi

	if [ -n "${listen_addr}" ]; then
		echo "${listen_addr}" | grep -qE '^[0-9A-Za-z_.:\[\]-]+$' || { json_init; json_add_string "error" "invalid listen_addr"; json_dump; return; }
	fi

	if [ -n "${listen_port}" ]; then
		echo "${listen_port}" | grep -qE '^[0-9]+$' || { json_init; json_add_string "error" "invalid listen_port"; json_dump; return; }
		[ "${listen_port}" -ge 1 ] && [ "${listen_port}" -le 65535 ] || { json_init; json_add_string "error" "listen_port out of range"; json_dump; return; }
	fi

	uci set "nginx_manager.${site_id}=site"
	uci set "nginx_manager.${site_id}.name=${name}"
	[ -n "${mode}" ] && uci set "nginx_manager.${site_id}.mode=${mode}"
	[ -n "${server_name}" ] && uci set "nginx_manager.${site_id}.server_name=${server_name}"
	[ -n "${proxy_pass}" ] && uci set "nginx_manager.${site_id}.proxy_pass=${proxy_pass}"
	[ -n "${root}" ] && uci set "nginx_manager.${site_id}.root=${root}"
	[ -n "${index}" ] && uci set "nginx_manager.${site_id}.index=${index}"
	[ -n "${websocket}" ] && uci set "nginx_manager.${site_id}.websocket=${websocket}"
	# Backward compat: migrate proxy_type=websocket → http + websocket=1
	if [ "${proxy_type}" = "websocket" ]; then
		uci set "nginx_manager.${site_id}.proxy_type=http"
		uci set "nginx_manager.${site_id}.websocket=1"
	else
		[ -n "${proxy_type}" ] && uci set "nginx_manager.${site_id}.proxy_type=${proxy_type}"
	fi
	[ -n "${grpc_path}" ] && uci set "nginx_manager.${site_id}.grpc_path=${grpc_path}" || uci -q delete "nginx_manager.${site_id}.grpc_path"
	[ -n "${grpc_pass}" ] && uci set "nginx_manager.${site_id}.grpc_pass=${grpc_pass}" || uci -q delete "nginx_manager.${site_id}.grpc_pass"
	[ -n "${custom_proxy_headers}" ] && uci set "nginx_manager.${site_id}.custom_proxy_headers=${custom_proxy_headers}" || uci -q delete "nginx_manager.${site_id}.custom_proxy_headers"
	[ -n "${redirect_https}" ] && uci set "nginx_manager.${site_id}.redirect_https=${redirect_https}"
	[ -n "${redirect_http_port}" ] && uci set "nginx_manager.${site_id}.redirect_http_port=${redirect_http_port}" || uci -q delete "nginx_manager.${site_id}.redirect_http_port"
	[ -n "${proxy_host}" ] && uci set "nginx_manager.${site_id}.proxy_host=${proxy_host}"
	[ -n "${proxy_xff}" ] && uci set "nginx_manager.${site_id}.proxy_xff=${proxy_xff}"
	[ -n "${proxy_xfp}" ] && uci set "nginx_manager.${site_id}.proxy_xfp=${proxy_xfp}"
	[ -n "${proxy_xri}" ] && uci set "nginx_manager.${site_id}.proxy_xri=${proxy_xri}"
	[ -n "${ssl_cert}" ] && uci set "nginx_manager.${site_id}.ssl_cert=${ssl_cert}" || uci -q delete "nginx_manager.${site_id}.ssl_cert"
	[ -n "${ssl_protocols}" ] && uci set "nginx_manager.${site_id}.ssl_protocols=${ssl_protocols}" || uci -q delete "nginx_manager.${site_id}.ssl_protocols"
	[ -n "${ssl_ciphers}" ] && uci set "nginx_manager.${site_id}.ssl_ciphers=${ssl_ciphers}" || uci -q delete "nginx_manager.${site_id}.ssl_ciphers"
	[ -n "${hsts_max_age}" ] && uci set "nginx_manager.${site_id}.hsts_max_age=${hsts_max_age}" || uci -q delete "nginx_manager.${site_id}.hsts_max_age"
	[ -n "${access_log}" ] && uci set "nginx_manager.${site_id}.access_log=${access_log}"
	[ -n "${error_log}" ] && uci set "nginx_manager.${site_id}.error_log=${error_log}"
	[ -n "${custom_server_block}" ] && uci set "nginx_manager.${site_id}.custom_server_block=${custom_server_block}" || uci -q delete "nginx_manager.${site_id}.custom_server_block"
	[ -n "${redirect_target}" ] && uci set "nginx_manager.${site_id}.redirect_target=${redirect_target}" || uci -q delete "nginx_manager.${site_id}.redirect_target"
	[ -n "${enabled}" ] && uci set "nginx_manager.${site_id}.enabled=${enabled}"
	[ -n "${proxy_connect_timeout}" ] && uci set "nginx_manager.${site_id}.proxy_connect_timeout=${proxy_connect_timeout}" || uci -q delete "nginx_manager.${site_id}.proxy_connect_timeout"
	[ -n "${proxy_read_timeout}" ] && uci set "nginx_manager.${site_id}.proxy_read_timeout=${proxy_read_timeout}" || uci -q delete "nginx_manager.${site_id}.proxy_read_timeout"
	[ -n "${proxy_send_timeout}" ] && uci set "nginx_manager.${site_id}.proxy_send_timeout=${proxy_send_timeout}" || uci -q delete "nginx_manager.${site_id}.proxy_send_timeout"

	# Migrate old listen list to new listen_addr/listen_port if present
	uci -q delete "nginx_manager.${site_id}.listen"

	# Set listen_addr and listen_port (allow empty listen_addr for all-interfaces)
	uci set "nginx_manager.${site_id}.listen_addr=${listen_addr:-}"
	uci set "nginx_manager.${site_id}.listen_port=${listen_port:-80}"

	uci commit nginx_manager

	local apply_result
	apply_result="$("${NGINX_MANAGER_GEN}" apply 2>&1)"
	local apply_exit=$?

	if [ "${apply_exit}" -ne 0 ]; then
		json_init
		json_add_string "error" "apply failed"
		json_add_string "detail" "${apply_result}"
		json_dump
		return
	fi

	json_init
	json_add_string "result" "ok"
	json_dump
}

handle_delete_site() {
	local site_id
	json_get_var site_id "id"
	[ -z "${site_id}" ] && { json_init; json_add_string "error" "missing id"; json_dump; return; }
	validate_uci_id "${site_id}" || { json_init; json_add_string "error" "invalid id"; json_dump; return; }

	uci -q get "nginx_manager.${site_id}" >/dev/null 2>&1 || {
		json_init
		json_add_string "error" "site not found"
		json_dump
		return
	}

	uci delete "nginx_manager.${site_id}"
	uci commit nginx_manager

	run_apply_or_error || return

	json_init
	json_add_string "result" "ok"
	json_dump
}

handle_enable_site() {
	local site_id
	json_get_var site_id "id"
	[ -z "${site_id}" ] && { json_init; json_add_string "error" "missing id"; json_dump; return; }
	validate_uci_id "${site_id}" || { json_init; json_add_string "error" "invalid id"; json_dump; return; }

	uci -q get "nginx_manager.${site_id}" >/dev/null 2>&1 || {
		json_init
