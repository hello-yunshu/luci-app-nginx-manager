# Write ACME task status to a temp file (atomic via rename)
_acme_task_write_status() {
	local cert_id="$1" status="$2" detail="${3:-}" command="${4:-}"
	local task_file="/tmp/acme-task-${cert_id}.json"
	local tmp_file="${task_file}.tmp"
	json_init
	json_add_string "status" "${status}"
	[ -n "${detail}" ] && json_add_string "detail" "${detail}"
	[ -n "${command}" ] && json_add_string "command" "${command}"
	json_dump > "${tmp_file}"
	mv "${tmp_file}" "${task_file}"
}

_acme_cert_set_status() {
	local cert_id="$1" status="$2" detail="${3:-}" command="${4:-}"
	local persistent_detail

	uci -q get "nginx_manager.${cert_id}" >/dev/null 2>&1 || return 0
	uci set "nginx_manager.${cert_id}.acme_status=${status}"
	uci set "nginx_manager.${cert_id}.acme_updated=$(date '+%Y-%m-%d %H:%M:%S')"

	if [ -n "${detail}" ]; then
		persistent_detail="$(printf '%s' "${detail}" | tr '\r\n' '  ' | cut -c 1-512)"
		uci set "nginx_manager.${cert_id}.acme_detail=${persistent_detail}"
	elif [ "${status}" = "running" ] || [ "${status}" = "success" ]; then
		uci -q delete "nginx_manager.${cert_id}.acme_detail" 2>/dev/null
	fi

	[ -n "${command}" ] && uci set "nginx_manager.${cert_id}.acme_command=${command}"
	uci commit nginx_manager
}

# Check if an ACME task is already running for the given cert_id
_acme_task_is_running() {
	local cert_id="$1"
	local task_file="/tmp/acme-task-${cert_id}.json"
	[ -f "${task_file}" ] && grep -q '"running"' "${task_file}"
}

ACME_ACCOUNT_EMAIL=""
ACME_ACCOUNT_SECTION_COUNT=0

_acme_set_account_section() {
	local section="$1"
	uci set "acme.${section}.account_email=${ACME_ACCOUNT_EMAIL}"
	uci -q get "acme.${section}.debug" >/dev/null 2>&1 || uci set "acme.${section}.debug=0"
	ACME_ACCOUNT_SECTION_COUNT=$((ACME_ACCOUNT_SECTION_COUNT + 1))
}

ensure_acme_account_config() {
	local account_email="$1"

	ACME_ACCOUNT_EMAIL="${account_email}"
	ACME_ACCOUNT_SECTION_COUNT=0
	config_load acme
	config_foreach _acme_set_account_section acme

	if [ "${ACME_ACCOUNT_SECTION_COUNT}" -eq 0 ]; then
		uci set acme.acme=acme
		uci set "acme.acme.account_email=${account_email}"
		uci set acme.acme.debug='0'
	fi

	uci commit acme
}

_acme_record_config() {
	local cert_id="$1" cert_name="$2" domain="$3" cert_dir="$4" validation_method="$5" dns_api="$6" status="$7" auto_renew="${8:-1}" dns_wait="${9:-}"
	local cert_subdir="${cert_dir}/${cert_id}"

	uci set "nginx_manager.${cert_id}=cert"
	uci set "nginx_manager.${cert_id}.name=${cert_name}"
	uci set "nginx_manager.${cert_id}.type=acme"
	uci set "nginx_manager.${cert_id}.cert_path=${cert_subdir}/fullchain.pem"
	uci set "nginx_manager.${cert_id}.key_path=${cert_subdir}/privkey.pem"
	uci set "nginx_manager.${cert_id}.domain=${domain}"
	uci set "nginx_manager.${cert_id}.auto_renew=${auto_renew}"
	uci set "nginx_manager.${cert_id}.validation_method=${validation_method}"
	if [ "${validation_method}" = "dns" ]; then
		uci set "nginx_manager.${cert_id}.dns_api=${dns_api}"
		if [ -n "${dns_wait}" ]; then
			uci set "nginx_manager.${cert_id}.dns_wait=${dns_wait}"
		else
			uci -q delete "nginx_manager.${cert_id}.dns_wait" 2>/dev/null
		fi
	else
		uci -q delete "nginx_manager.${cert_id}.dns_api" 2>/dev/null
		uci -q delete "nginx_manager.${cert_id}.dns_wait" 2>/dev/null
	fi
	uci set "nginx_manager.${cert_id}.acme_status=${status}"
	uci set "nginx_manager.${cert_id}.acme_command=/etc/init.d/acme renew"
	uci -q delete "nginx_manager.${cert_id}.acme_detail" 2>/dev/null
	uci commit nginx_manager
}

_acme_recent_log() {
	logread -e acme 2>/dev/null | tail -n 80
}

_acme_restore_enabled() {
	local cert_id="$1" auto_renew="$2"

	uci -q get "acme.${cert_id}" >/dev/null 2>&1 || return 0
	case "${auto_renew}" in
		0|1) ;;
		*) auto_renew="1" ;;
	esac
	uci set "acme.${cert_id}.enabled=${auto_renew}"
	uci commit acme
}

_acme_wait_for_service() {
	local cert_id="$1"
	local elapsed=0

	# OpenWrt acme renew runs the real issuance in a procd instance.
	# Wait for that instance before checking certificate files or cleaning up.
	sleep "${ACME_RUN_POLL_INTERVAL}"
	elapsed=$((elapsed + ACME_RUN_POLL_INTERVAL))

	while /etc/init.d/acme running "${cert_id}" >/dev/null 2>&1; do
		[ "${elapsed}" -ge "${ACME_RUN_TIMEOUT}" ] && return 1
		sleep "${ACME_RUN_POLL_INTERVAL}"
		elapsed=$((elapsed + ACME_RUN_POLL_INTERVAL))
	done

	return 0
}

# Remove stale symlinks in /etc/ssl/acme/ for a domain so the acme hook's
# link_certs() can create fresh ones.  Without this, a previous failed run
# may leave broken symlinks that cause "ln: File exists" errors.
_cleanup_acme_ssl_links() {
	local domain="$1"
	local f
	for f in "${domain}.crt" "${domain}.key" "${domain}.fullchain.crt" "${domain}.combined.crt" "${domain}.chain.crt"; do
		[ -L "/etc/ssl/acme/${f}" ] && rm -f "/etc/ssl/acme/${f}"
	done
}

# Background worker for ACME issue
_acme_issue_worker() {
	local cert_id="$1" cert_name="$2" domain="$3" cert_dir="$4" validation_method="$5" dns_api="$6" auto_renew="$7" dns_wait="$8"

	# Remove stale symlinks so hook's link_certs() can create fresh ones
	_cleanup_acme_ssl_links "${domain}"

	# Run acme to issue the certificate
	local acme_output
	acme_output="$(/etc/init.d/acme renew 2>&1)"
	local acme_exit=$?

	if [ ${acme_exit} -ne 0 ]; then
		[ "${validation_method}" = "webroot" ] && cleanup_acme_challenge_config "${cert_id}"
		_acme_restore_enabled "${cert_id}" "${auto_renew}"
		_acme_cert_set_status "${cert_id}" "failed" "${acme_output}" "/etc/init.d/acme renew"
		_acme_task_write_status "${cert_id}" "failed" "${acme_output}" "/etc/init.d/acme renew"
		return
	fi

	_acme_task_write_status "${cert_id}" "running" "${acme_output}" "/etc/init.d/acme renew"

	if ! _acme_wait_for_service "${cert_id}"; then
		[ "${validation_method}" = "webroot" ] && cleanup_acme_challenge_config "${cert_id}"
		_acme_restore_enabled "${cert_id}" "${auto_renew}"
		_acme_cert_set_status "${cert_id}" "failed" "ACME operation timed out; see system log for details" "/etc/init.d/acme renew"
		_acme_task_write_status "${cert_id}" "failed" "ACME operation timed out; see system log for details" "/etc/init.d/acme renew"
		return
	fi

	[ "${validation_method}" = "webroot" ] && cleanup_acme_challenge_config "${cert_id}"

	# Check if certificate was issued successfully
	local acme_cert="/etc/ssl/acme/${domain}.fullchain.crt"
	local acme_key="/etc/ssl/acme/${domain}.key"

	# Fallback: if standard paths are missing/broken, the acme hook may have
	# failed to create symlinks (e.g. state_dir was empty).  Search common
	# acme.sh state directories and repair the /etc/ssl/acme symlinks.
	if [ ! -f "${acme_cert}" ] || [ ! -f "${acme_key}" ]; then
		local _found_cert="" _found_key=""
		for _sd in /etc/acme /.acme.sh /root/.acme.sh; do
			for _sub in "${_sd}/${domain}_ecc" "${_sd}/${domain}"; do
				if [ -f "${_sub}/fullchain.cer" ] && [ -f "${_sub}/${domain}.key" ]; then
					_found_cert="${_sub}/fullchain.cer"
					_found_key="${_sub}/${domain}.key"
					break 2
				fi
			done
		done
		if [ -n "${_found_cert}" ] && [ -n "${_found_key}" ]; then
			mkdir -p /etc/ssl/acme
			ln -sf "${_found_cert}" "/etc/ssl/acme/${domain}.fullchain.crt"
			ln -sf "${_found_key}" "/etc/ssl/acme/${domain}.key"
		fi
	fi

	if [ ! -f "${acme_cert}" ] || [ ! -f "${acme_key}" ]; then
		_acme_restore_enabled "${cert_id}" "${auto_renew}"
		_acme_cert_set_status "${cert_id}" "failed" "ACME finished without producing certificate files; see system log for details" "/etc/init.d/acme renew"
		_acme_task_write_status "${cert_id}" "failed" "ACME finished without producing certificate files; see system log for details" "/etc/init.d/acme renew"
		return
	fi

	local cert_subdir="${cert_dir}/${cert_id}"
	mkdir -p "${cert_subdir}"

	# Symlink to acme certificate files
	ln -sf "${acme_cert}" "${cert_subdir}/fullchain.pem"
	ln -sf "${acme_key}" "${cert_subdir}/privkey.pem"

	_acme_record_config "${cert_id}" "${cert_name}" "${domain}" "${cert_dir}" "${validation_method}" "${dns_api}" "success" "${auto_renew}" "${dns_wait}"
	uci -q delete "nginx_manager.${cert_id}.acme_detail" 2>/dev/null
	uci commit nginx_manager

	# Reload nginx to pick up the new certificate
	/etc/init.d/nginx reload >/dev/null 2>&1

	_acme_restore_enabled "${cert_id}" "${auto_renew}"
	_acme_task_write_status "${cert_id}" "success" "" "/etc/init.d/acme renew"
}

handle_acme_issue() {
	local cert_name domain account_email validation_method dns_api credentials dns_wait auto_renew cert_id

	json_get_var cert_name "id"
	json_get_var domain "domain"
	json_get_var account_email "account_email"
	json_get_var validation_method "validation_method"
	json_get_var dns_api "dns_api"
	json_get_var credentials "credentials"
	json_get_var dns_wait "dns_wait"
	json_get_var auto_renew "auto_renew"

	[ -z "${cert_name}" ] && { json_init; json_add_string "error" "missing id"; json_dump; return; }
	validate_name "${cert_name}" || { json_init; json_add_string "error" "invalid id"; json_dump; return; }
	[ -z "${domain}" ] && { json_init; json_add_string "error" "missing domain"; json_dump; return; }
	validate_domain "${domain}" || { json_init; json_add_string "error" "invalid domain"; json_dump; return; }
	[ -z "${account_email}" ] && { json_init; json_add_string "error" "missing acme account email"; json_dump; return; }
	validate_acme_account_email "${account_email}" || { json_init; json_add_string "error" "invalid acme account email"; json_dump; return; }
	[ -z "${validation_method}" ] && validation_method="webroot"
	case "${validation_method}" in
		webroot|dns|standalone) ;;
		*) { json_init; json_add_string "error" "invalid acme validation method"; json_dump; return; } ;;
	esac
	if { [ "${validation_method}" = "webroot" ] || [ "${validation_method}" = "standalone" ]; } && echo "${domain}" | grep -q '\*'; then
		json_init; json_add_string "error" "wildcard domains not supported for http acme"; json_dump; return
	fi
	if [ "${validation_method}" = "dns" ]; then
		[ -n "${dns_api}" ] || { json_init; json_add_string "error" "missing dns api"; json_dump; return; }
		validate_acme_dns_api "${dns_api}" || { json_init; json_add_string "error" "invalid dns api"; json_dump; return; }
		[ -n "${credentials}" ] || { json_init; json_add_string "error" "missing dns credentials"; json_dump; return; }
		if [ ! -d /usr/lib/acme/dnsapi ] && [ ! -d /usr/lib/acme/client/dnsapi ]; then
			json_init; json_add_string "error" "acme dns api package not installed"; json_dump; return;
		fi
		printf '%s\n' "${credentials}" | while IFS= read -r credential_line; do
			credential_line="$(printf '%s' "${credential_line}" | tr -d '\r')"
			[ -z "${credential_line}" ] && continue
			validate_acme_credential "${credential_line}" || exit 1
		done || { json_init; json_add_string "error" "invalid dns credentials"; json_dump; return; }
	fi
	if [ -n "${dns_wait}" ]; then
		validate_positive_number "${dns_wait}" || { json_init; json_add_string "error" "invalid dns wait seconds"; json_dump; return; }
	fi
	[ -z "${auto_renew}" ] && auto_renew="1"
	case "${auto_renew}" in
		0|1) ;;
		*) { json_init; json_add_string "error" "invalid auto renew"; json_dump; return; } ;;
	esac

	# Check for duplicate cert_id
	resolve_new_cert_id "${cert_name}" || { json_init; json_add_string "error" "${_RESOLVE_CERT_ID_ERROR}"; json_dump; return; }
	cert_id="${_RESOLVED_CERT_ID}"

	# Prevent concurrent ACME operations for the same cert
	_acme_task_is_running "${cert_id}" && {
		json_init; json_add_string "error" "ACME operation already in progress for this certificate"; json_dump; return
	}

	# Check if acme package is installed
	if [ ! -x /etc/init.d/acme ]; then
		json_init
		json_add_string "error" "acme package not installed"
		json_dump
		return
	fi

	load_global_config

	# Create UCI config in /etc/config/acme
	ensure_acme_account_config "${account_email}"

	# Create cert section in acme config
	uci set "acme.${cert_id}=cert"
	uci set "acme.${cert_id}.enabled=1"
	uci set "acme.${cert_id}.validation_method=${validation_method}"
	uci set "acme.${cert_id}.key_type=ec256"
	uci -q delete "acme.${cert_id}.dns" 2>/dev/null
	uci -q delete "acme.${cert_id}.credentials" 2>/dev/null
	uci -q delete "acme.${cert_id}.dns_wait" 2>/dev/null
	if [ "${validation_method}" = "dns" ]; then
		uci set "acme.${cert_id}.dns=${dns_api}"
		printf '%s\n' "${credentials}" | while IFS= read -r credential_line; do
			credential_line="$(printf '%s' "${credential_line}" | tr -d '\r')"
			[ -z "${credential_line}" ] && continue
			uci add_list "acme.${cert_id}.credentials=${credential_line}"
		done
		[ -n "${dns_wait}" ] && uci set "acme.${cert_id}.dns_wait=${dns_wait}"
	fi
	uci delete "acme.${cert_id}.domains" 2>/dev/null
	uci add_list "acme.${cert_id}.domains=${domain}"
	uci commit acme

	_acme_record_config "${cert_id}" "${cert_name}" "${domain}" "${CERT_DIR}" "${validation_method}" "${dns_api}" "running" "${auto_renew}"
	_acme_task_write_status "${cert_id}" "running" "ACME request queued" "/etc/init.d/acme renew"

	if [ "${validation_method}" = "webroot" ]; then
		local challenge_output
		challenge_output="$(prepare_acme_challenge_config "${cert_id}" "${domain}" 2>&1)"
		if [ $? -ne 0 ]; then
			_acme_restore_enabled "${cert_id}" "${auto_renew}"
			_acme_cert_set_status "${cert_id}" "failed" "${challenge_output}" "/etc/init.d/acme renew"
			_acme_task_write_status "${cert_id}" "failed" "${challenge_output}" "/etc/init.d/acme renew"

			json_init
			json_add_string "task_id" "${cert_id}"
			json_add_string "status" "failed"
			json_dump
			return
		fi
	fi

	# Write initial status and spawn background worker
	_acme_cert_set_status "${cert_id}" "running" "" "/etc/init.d/acme renew"
	_acme_task_write_status "${cert_id}" "running" "ACME is running in the background" "/etc/init.d/acme renew"
	(_acme_issue_worker "${cert_id}" "${cert_name}" "${domain}" "${CERT_DIR}" "${validation_method}" "${dns_api}" "${auto_renew}" "${dns_wait}" &)

	json_init
	json_add_string "task_id" "${cert_id}"
	json_add_string "status" "running"
	json_dump
}

# Background worker for ACME renew
_acme_renew_worker() {
	local cert_id="$1" domain="$2" validation_method="$3" auto_renew="$4"

	# Remove stale symlinks so hook's link_certs() can create fresh ones
	_cleanup_acme_ssl_links "${domain}"

	# Run acme renewal
	local acme_output
	acme_output="$(/etc/init.d/acme renew 2>&1)"
	local acme_exit=$?

	if [ ${acme_exit} -ne 0 ]; then
		[ "${validation_method}" = "webroot" ] && cleanup_acme_challenge_config "${cert_id}"
		_acme_restore_enabled "${cert_id}" "${auto_renew}"
		_acme_cert_set_status "${cert_id}" "failed" "${acme_output}" "/etc/init.d/acme renew"
		_acme_task_write_status "${cert_id}" "failed" "${acme_output}" "/etc/init.d/acme renew"
		return
	fi

	_acme_task_write_status "${cert_id}" "running" "${acme_output}" "/etc/init.d/acme renew"

	if ! _acme_wait_for_service "${cert_id}"; then
		[ "${validation_method}" = "webroot" ] && cleanup_acme_challenge_config "${cert_id}"
		_acme_restore_enabled "${cert_id}" "${auto_renew}"
		_acme_cert_set_status "${cert_id}" "failed" "ACME operation timed out; see system log for details" "/etc/init.d/acme renew"
		_acme_task_write_status "${cert_id}" "failed" "ACME operation timed out; see system log for details" "/etc/init.d/acme renew"
		return
	fi

	[ "${validation_method}" = "webroot" ] && cleanup_acme_challenge_config "${cert_id}"

	# Verify renewal actually produced updated cert files (consistent with issue worker)
	local acme_cert="/etc/ssl/acme/${domain}.fullchain.crt"
	local acme_key="/etc/ssl/acme/${domain}.key"

	# Fallback: repair /etc/ssl/acme symlinks if the hook failed to create them
	if [ ! -f "${acme_cert}" ] || [ ! -f "${acme_key}" ]; then
		local _found_cert="" _found_key=""
		for _sd in /etc/acme /.acme.sh /root/.acme.sh; do
			for _sub in "${_sd}/${domain}_ecc" "${_sd}/${domain}"; do
				if [ -f "${_sub}/fullchain.cer" ] && [ -f "${_sub}/${domain}.key" ]; then
					_found_cert="${_sub}/fullchain.cer"
					_found_key="${_sub}/${domain}.key"
					break 2
				fi
			done
		done
		if [ -n "${_found_cert}" ] && [ -n "${_found_key}" ]; then
			mkdir -p /etc/ssl/acme
			ln -sf "${_found_cert}" "/etc/ssl/acme/${domain}.fullchain.crt"
			ln -sf "${_found_key}" "/etc/ssl/acme/${domain}.key"
		fi
	fi

	if [ ! -f "${acme_cert}" ] || [ ! -f "${acme_key}" ]; then
		_acme_restore_enabled "${cert_id}" "${auto_renew}"
		_acme_cert_set_status "${cert_id}" "failed" "ACME finished without producing certificate files; see system log for details" "/etc/init.d/acme renew"
		_acme_task_write_status "${cert_id}" "failed" "ACME finished without producing certificate files; see system log for details" "/etc/init.d/acme renew"
		return
	fi

	# Reload nginx to pick up renewed certificate
	/etc/init.d/nginx reload >/dev/null 2>&1

	_acme_restore_enabled "${cert_id}" "${auto_renew}"
	_acme_cert_set_status "${cert_id}" "success" "" "/etc/init.d/acme renew"
	_acme_task_write_status "${cert_id}" "success" "" "/etc/init.d/acme renew"
}

handle_acme_update() {
	local cert_id domain account_email validation_method dns_api credentials dns_wait auto_renew

	json_get_var cert_id "id"
	json_get_var domain "domain"
	json_get_var account_email "account_email"
	json_get_var validation_method "validation_method"
	json_get_var dns_api "dns_api"
	json_get_var credentials "credentials"
	json_get_var dns_wait "dns_wait"
	json_get_var auto_renew "auto_renew"

	[ -z "${cert_id}" ] && { json_init; json_add_string "error" "missing id"; json_dump; return; }
	validate_uci_id "${cert_id}" || { json_init; json_add_string "error" "invalid id"; json_dump; return; }

	# Verify cert exists and is acme type
	local cert_type
	cert_type="$(uci -q get "nginx_manager.${cert_id}.type")" || {
		json_init; json_add_string "error" "cert not found"; json_dump; return
	}
	[ "${cert_type}" = "acme" ] || {
		json_init; json_add_string "error" "not an acme certificate"; json_dump; return
	}

	# Validate provided fields
	[ -n "${domain}" ] && { validate_domain "${domain}" || { json_init; json_add_string "error" "invalid domain"; json_dump; return; }; }
	[ -n "${account_email}" ] && { validate_acme_account_email "${account_email}" || { json_init; json_add_string "error" "invalid acme account email"; json_dump; return; }; }
	if [ -n "${validation_method}" ]; then
		case "${validation_method}" in
			webroot|dns|standalone) ;;
			*) { json_init; json_add_string "error" "invalid acme validation method"; json_dump; return; } ;;
		esac
	fi
	if [ -n "${auto_renew}" ]; then
		case "${auto_renew}" in
			0|1) ;;
			*) { json_init; json_add_string "error" "invalid auto renew"; json_dump; return; } ;;
		esac
	fi

	# Read current values
	local cur_domain cur_validation_method cur_dns_api cur_auto_renew cur_dns_wait cur_account_email
	cur_domain="$(uci -q get "nginx_manager.${cert_id}.domain")" || cur_domain=""
	cur_validation_method="$(uci -q get "nginx_manager.${cert_id}.validation_method")" || cur_validation_method="webroot"
	cur_dns_api="$(uci -q get "nginx_manager.${cert_id}.dns_api")" || cur_dns_api=""
	cur_auto_renew="$(uci -q get "nginx_manager.${cert_id}.auto_renew")" || cur_auto_renew="1"
	cur_dns_wait="$(uci -q get "nginx_manager.${cert_id}.dns_wait")" || cur_dns_wait=""
	cur_account_email="$(uci -q get "acme.acme.account_email")" || cur_account_email=""

	# Apply new values (fall back to current if not provided)
	local new_domain new_validation_method new_dns_api new_auto_renew new_dns_wait new_account_email
	new_domain="${domain:-${cur_domain}}"
	new_validation_method="${validation_method:-${cur_validation_method}}"
	new_dns_api="${dns_api:-${cur_dns_api}}"
	new_auto_renew="${auto_renew:-${cur_auto_renew}}"
	new_dns_wait="${dns_wait:-${cur_dns_wait}}"
	new_account_email="${account_email:-${cur_account_email}}"

	# Validate DNS-specific fields with resolved values
	if [ "${new_validation_method}" = "dns" ]; then
		[ -n "${new_dns_api}" ] || { json_init; json_add_string "error" "missing dns api"; json_dump; return; }
		validate_acme_dns_api "${new_dns_api}" || { json_init; json_add_string "error" "invalid dns api"; json_dump; return; }
	fi
	# Wildcard check for non-DNS methods
	if [ "${new_validation_method}" != "dns" ] && echo "${new_domain}" | grep -q '\*'; then
		json_init; json_add_string "error" "wildcard domains not supported for http acme"; json_dump; return
	fi
	if [ -n "${new_dns_wait}" ]; then
		validate_positive_number "${new_dns_wait}" || { json_init; json_add_string "error" "invalid dns wait seconds"; json_dump; return; }
	fi

	# Determine if re-issue is needed (domain, validation_method, dns_api changed)
	local needs_reissue="0"
	[ "${new_domain}" != "${cur_domain}" ] && needs_reissue="1"
	[ "${new_validation_method}" != "${cur_validation_method}" ] && needs_reissue="1"
	[ "${new_validation_method}" = "dns" ] && [ "${new_dns_api}" != "${cur_dns_api}" ] && needs_reissue="1"

	# Update nginx_manager UCI
	uci set "nginx_manager.${cert_id}.domain=${new_domain}"
	uci set "nginx_manager.${cert_id}.auto_renew=${new_auto_renew}"
	uci set "nginx_manager.${cert_id}.validation_method=${new_validation_method}"
	if [ "${new_validation_method}" = "dns" ]; then
		uci set "nginx_manager.${cert_id}.dns_api=${new_dns_api}"
		if [ -n "${new_dns_wait}" ]; then
			uci set "nginx_manager.${cert_id}.dns_wait=${new_dns_wait}"
		else
			uci -q delete "nginx_manager.${cert_id}.dns_wait" 2>/dev/null
		fi
	else
		uci -q delete "nginx_manager.${cert_id}.dns_api" 2>/dev/null
		uci -q delete "nginx_manager.${cert_id}.dns_wait" 2>/dev/null
	fi
	uci commit nginx_manager

	# Update acme UCI
	if [ -n "${account_email}" ]; then
		ensure_acme_account_config "${new_account_email}"
	fi
	if uci -q get "acme.${cert_id}" >/dev/null 2>&1; then
		uci set "acme.${cert_id}.validation_method=${new_validation_method}"
		uci -q delete "acme.${cert_id}.dns" 2>/dev/null
		uci -q delete "acme.${cert_id}.dns_wait" 2>/dev/null
		if [ "${new_validation_method}" = "dns" ]; then
			uci set "acme.${cert_id}.dns=${new_dns_api}"
			if [ -n "${credentials}" ]; then
				uci -q delete "acme.${cert_id}.credentials" 2>/dev/null
				printf '%s\n' "${credentials}" | while IFS= read -r credential_line; do
					credential_line="$(printf '%s' "${credential_line}" | tr -d '\r')"
					[ -z "${credential_line}" ] && continue
					validate_acme_credential "${credential_line}" || exit 1
					uci add_list "acme.${cert_id}.credentials=${credential_line}"
				done || { json_init; json_add_string "error" "invalid dns credentials"; json_dump; return; }
			fi
			[ -n "${new_dns_wait}" ] && uci set "acme.${cert_id}.dns_wait=${new_dns_wait}"
		else
			uci -q delete "acme.${cert_id}.credentials" 2>/dev/null
		fi
		uci delete "acme.${cert_id}.domains" 2>/dev/null
		uci add_list "acme.${cert_id}.domains=${new_domain}"
	fi
	uci commit acme

	json_init
	json_add_string "id" "${cert_id}"
	json_add_string "needs_reissue" "${needs_reissue}"
	json_dump
}

handle_acme_renew() {
	local cert_id disable_auto_renew

	json_get_var cert_id "id"
	json_get_var disable_auto_renew "disable_auto_renew"

	[ -z "${cert_id}" ] && { json_init; json_add_string "error" "missing id"; json_dump; return; }
	validate_uci_id "${cert_id}" || { json_init; json_add_string "error" "invalid id"; json_dump; return; }
	case "${disable_auto_renew}" in
		''|0|1) ;;
		*) { json_init; json_add_string "error" "invalid auto renew"; json_dump; return; } ;;
	esac

	# Prevent concurrent ACME operations for the same cert
	_acme_task_is_running "${cert_id}" && {
		json_init; json_add_string "error" "ACME operation already in progress for this certificate"; json_dump; return
	}

	load_global_config

	# Check if acme package is installed
	if [ ! -x /etc/init.d/acme ]; then
		json_init
		json_add_string "error" "acme package not installed"
		json_dump
		return
	fi

	# Verify cert exists in nginx_manager
	local cert_type domain validation_method auto_renew
	cert_type="$(uci -q get "nginx_manager.${cert_id}.type")" || {
		json_init; json_add_string "error" "cert not found"; json_dump; return
	}
	domain="$(uci -q get "nginx_manager.${cert_id}.domain")" || domain=""
	validation_method="$(uci -q get "nginx_manager.${cert_id}.validation_method")" || validation_method="$(uci -q get "acme.${cert_id}.validation_method" 2>/dev/null)"
	[ -z "${validation_method}" ] && validation_method="webroot"
	auto_renew="$(uci -q get "nginx_manager.${cert_id}.auto_renew")" || auto_renew="1"
	[ "${disable_auto_renew}" = "1" ] && auto_renew="0"

	if [ "${cert_type}" != "acme" ]; then
		json_init
		json_add_string "error" "not an acme certificate"
		json_dump
		return
	fi
	[ -z "${domain}" ] && { json_init; json_add_string "error" "missing domain"; json_dump; return; }
	case "${validation_method}" in
		webroot|dns|standalone) ;;
		*) { json_init; json_add_string "error" "invalid acme validation method"; json_dump; return; } ;;
	esac
	if { [ "${validation_method}" = "webroot" ] || [ "${validation_method}" = "standalone" ]; } && echo "${domain}" | grep -q '\*'; then
		json_init; json_add_string "error" "wildcard domains not supported for http acme"; json_dump; return
	fi

	# Verify cert exists in acme config
	uci -q get "acme.${cert_id}" >/dev/null 2>&1 || {
		json_init; json_add_string "error" "acme config not found"; json_dump; return
	}

	# Ensure it's enabled
	uci set "acme.${cert_id}.enabled=1"
	uci commit acme
	uci set "nginx_manager.${cert_id}.auto_renew=${auto_renew}"
	uci commit nginx_manager

	if [ "${validation_method}" = "webroot" ]; then
		local challenge_output
		challenge_output="$(prepare_acme_challenge_config "${cert_id}" "${domain}" 2>&1)"
		if [ $? -ne 0 ]; then
			_acme_restore_enabled "${cert_id}" "${auto_renew}"
			_acme_cert_set_status "${cert_id}" "failed" "${challenge_output}" "/etc/init.d/acme renew"
			_acme_task_write_status "${cert_id}" "failed" "${challenge_output}" "/etc/init.d/acme renew"

			json_init
			json_add_string "task_id" "${cert_id}"
			json_add_string "status" "failed"
			json_dump
			return
		fi
	fi

	# Write initial status and spawn background worker
	_acme_cert_set_status "${cert_id}" "running" "" "/etc/init.d/acme renew"
	_acme_task_write_status "${cert_id}" "running" "ACME is running in the background" "/etc/init.d/acme renew"
	(_acme_renew_worker "${cert_id}" "${domain}" "${validation_method}" "${auto_renew}" &)

	json_init
	json_add_string "task_id" "${cert_id}"
	json_add_string "status" "running"
	json_dump
}

handle_acme_status() {
	local task_id
	json_get_var task_id "task_id"

	[ -z "${task_id}" ] && { json_init; json_add_string "error" "missing task_id"; json_dump; return; }
	validate_uci_id "${task_id}" || { json_init; json_add_string "error" "invalid task_id"; json_dump; return; }

	local task_file="/tmp/acme-task-${task_id}.json"
	local status detail command recent_log task_json

	if [ -f "${task_file}" ]; then
		task_json="$(cat "${task_file}")"
		json_load "${task_json}" >/dev/null 2>&1
		json_get_var status "status"
		json_get_var detail "detail"
		json_get_var command "command"
	else
		status="$(uci -q get "nginx_manager.${task_id}.acme_status")" || status="unknown"
		detail="$(uci -q get "nginx_manager.${task_id}.acme_detail")" || detail=""
		command="$(uci -q get "nginx_manager.${task_id}.acme_command")" || command=""
	fi

	[ -z "${status}" ] && status="unknown"
	[ -z "${command}" ] && command="/etc/init.d/acme renew"
	recent_log="$(_acme_recent_log)"

	json_init
	json_add_string "status" "${status}"
	json_add_string "command" "${command}"
	[ -n "${detail}" ] && json_add_string "detail" "${detail}"
	[ -n "${recent_log}" ] && json_add_string "log" "${recent_log}"
	json_dump
}

