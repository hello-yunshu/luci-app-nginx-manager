handle_delete_cert() {
	local cert_id
	json_get_var cert_id "id"
	[ -z "${cert_id}" ] && { json_init; json_add_string "error" "missing id"; json_dump; return; }
	validate_uci_id "${cert_id}" || { json_init; json_add_string "error" "invalid id"; json_dump; return; }

	# Verify it's actually a cert section
	local section_type
	section_type="$(uci -q get "nginx_manager.${cert_id}")" || {
		json_init
		json_add_string "error" "cert not found"
		json_dump
		return
	}
	[ "${section_type}" != "cert" ] && {
		json_init
		json_add_string "error" "not a certificate"
		json_dump
		return
	}

	# If ACME cert, also clean up acme UCI config
	local cert_type
	cert_type="$(uci -q get "nginx_manager.${cert_id}.type")" || cert_type=""
	if [ "${cert_type}" = "acme" ]; then
		uci -q delete "acme.${cert_id}" 2>/dev/null
		uci -q commit acme
	fi

	# Remove cert directory
	load_global_config
	local cert_subdir="${CERT_DIR}/${cert_id}"
	if [ -d "${cert_subdir}" ]; then
		rm -rf "${cert_subdir}"
	fi

	# Clear ssl_cert references from any sites using this cert
	_DELETE_CERT_ID="${cert_id}"
	config_load nginx_manager
	config_foreach _clear_cert_reference site
	_DELETE_CERT_ID=""

	uci delete "nginx_manager.${cert_id}"

	uci commit nginx_manager

	# Clean up any ACME task status file
	rm -f "/tmp/acme-task-${cert_id}.json"

	# Regenerate nginx configs and reload
	run_apply_or_error || return

	json_init
	json_add_string "result" "ok"
	json_dump
}

_DELETE_CERT_ID=""
_clear_cert_reference() {
	local section="$1"
	local ssl_cert

	ssl_cert="$(uci -q get "nginx_manager.${section}.ssl_cert")" || ssl_cert=""
	[ "${ssl_cert}" = "${_DELETE_CERT_ID}" ] && uci -q delete "nginx_manager.${section}.ssl_cert"
}

