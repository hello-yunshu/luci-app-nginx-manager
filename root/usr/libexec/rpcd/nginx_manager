handle_upload_cert() {
	local cert_id name cert_content key_content domain

	json_get_var cert_id "id"
	json_get_var name "name"
	json_get_var cert_content "cert_content"
	json_get_var key_content "key_content"
	json_get_var domain "domain"

	[ -z "${cert_id}" ] && { json_init; json_add_string "error" "missing id"; json_dump; return; }
	validate_name "${cert_id}" || { json_init; json_add_string "error" "invalid id"; json_dump; return; }
	[ -z "${cert_content}" ] && { json_init; json_add_string "error" "missing cert_content"; json_dump; return; }
	[ -z "${key_content}" ] && { json_init; json_add_string "error" "missing key_content"; json_dump; return; }

	load_global_config

	local cert_subdir="${CERT_DIR}/${cert_id}"
	mkdir -p "${cert_subdir}"

	printf '%s' "${cert_content}" > "${cert_subdir}/fullchain.pem"
	printf '%s' "${key_content}" > "${cert_subdir}/privkey.pem"
	chmod 600 "${cert_subdir}/privkey.pem"

	uci set "nginx_manager.${cert_id}=cert"
	uci set "nginx_manager.${cert_id}.name=${name:-${cert_id}}"
	uci set "nginx_manager.${cert_id}.type=manual"
	uci set "nginx_manager.${cert_id}.cert_path=${cert_subdir}/fullchain.pem"
	uci set "nginx_manager.${cert_id}.key_path=${cert_subdir}/privkey.pem"
	[ -n "${domain}" ] && uci set "nginx_manager.${cert_id}.domain=${domain}"
	uci set "nginx_manager.${cert_id}.auto_renew=0"
	uci commit nginx_manager

	json_init
	json_add_string "result" "ok"
	json_dump
}

handle_issue_self_signed() {
	local cert_id name domain

	json_get_var cert_id "id"
	json_get_var name "name"
	json_get_var domain "domain"

	[ -z "${cert_id}" ] && { json_init; json_add_string "error" "missing id"; json_dump; return; }
	validate_name "${cert_id}" || { json_init; json_add_string "error" "invalid id"; json_dump; return; }
	[ -z "${domain}" ] && { json_init; json_add_string "error" "missing domain"; json_dump; return; }

	load_global_config

	local cert_subdir="${CERT_DIR}/${cert_id}"
	mkdir -p "${cert_subdir}"

	openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
		-keyout "${cert_subdir}/privkey.pem" \
		-out "${cert_subdir}/fullchain.pem" \
		-subj "/CN=${domain}" 2>/dev/null

	[ $? -ne 0 ] && { json_init; json_add_string "error" "openssl failed"; json_dump; return; }

	chmod 600 "${cert_subdir}/privkey.pem"

	uci set "nginx_manager.${cert_id}=cert"
	uci set "nginx_manager.${cert_id}.name=${name:-${cert_id}}"
	uci set "nginx_manager.${cert_id}.type=self_signed"
	uci set "nginx_manager.${cert_id}.cert_path=${cert_subdir}/fullchain.pem"
	uci set "nginx_manager.${cert_id}.key_path=${cert_subdir}/privkey.pem"
	uci set "nginx_manager.${cert_id}.domain=${domain}"
	uci set "nginx_manager.${cert_id}.auto_renew=0"
	uci commit nginx_manager

	json_init
	json_add_string "result" "ok"
	json_dump
}

handle_check_cert_expiry() {
	load_global_config

	json_init
	json_add_array "certificates"

	config_load nginx_manager
	config_foreach _check_cert_expiry cert

	json_close_array
	json_dump
}

_check_cert_expiry() {
	local section="$1"
	local cert_path name

	cert_path="$(uci -q get "nginx_manager.${section}.cert_path")" || return 0
	name="$(uci -q get "nginx_manager.${section}.name")" || name="${section}"

	[ -f "${cert_path}" ] || return 0

	local days
	days="$(get_cert_expiry "${cert_path}")" || days="-1"

	json_add_object ""
	json_add_string "id" "${section}"
	json_add_string "name" "${name}"
	json_add_string "days_remaining" "${days}"
	json_close_object
}

handle_get_logs() {
	local log_type lines filter site

	json_get_var log_type "type"
	json_get_var lines "lines"
	json_get_var filter "filter"
	json_get_var site "site"

	[ -z "${lines}" ] && lines="200"
	echo "${lines}" | grep -qE '^[0-9]+$' || lines="200"
	[ "${lines}" -gt 500 ] && lines="500"

	local log_paths log_path content found
	log_paths="$(resolve_log_paths "${log_type}" "${site}")" || {
		json_init
		json_add_string "error" "invalid log request"
		json_dump
		return
	}

	if [ -z "${log_paths}" ]; then
		json_init
		json_add_string "error" "log file not found"
		json_dump
		return
	fi

	content=""
	found="0"
	for log_path in ${log_paths}; do
		[ -f "${log_path}" ] || continue
		found="1"
		if [ -n "${content}" ]; then
			content="${content}
"
		fi
		content="${content}==> ${log_path} <=="
		if [ -n "${filter}" ]; then
			content="${content}
$(tail -n "${lines}" "${log_path}" | grep -F "${filter}" || true)"
		else
			content="${content}
$(tail -n "${lines}" "${log_path}")"
		fi
	done

	if [ "${found}" != "1" ]; then
		json_init
		json_add_string "error" "log file not found"
		json_dump
		return
	fi

	json_init
	json_add_string "content" "${content}"
	json_add_string "path" "${log_paths}"
	json_dump
}

resolve_log_paths() {
	local log_type="$1"
	local site="$2"
	local site_name log_path found

	if [ -n "${site}" ]; then
		validate_name "${site}" || return 1
		site_name="$(uci -q get "nginx_manager.${site}.name")" || site_name="${site}"
		validate_name "${site_name}" || return 1
	fi

	case "${log_type}" in
		error)
			if [ -n "${site}" ]; then
				echo "/var/log/nginx/${site_name}.error.log"
			else
				found="0"
				for log_path in /var/log/nginx/error.log /var/log/nginx/*.error.log; do
					[ -f "${log_path}" ] || continue
					echo "${log_path}"
					found="1"
				done
				[ "${found}" = "1" ] || true
			fi
			;;
		access)
			if [ -n "${site}" ]; then
				echo "/var/log/nginx/${site_name}.access.log"
			else
				found="0"
				for log_path in /var/log/nginx/access.log /var/log/nginx/*.access.log; do
					[ -f "${log_path}" ] || continue
					echo "${log_path}"
					found="1"
				done
				[ "${found}" = "1" ] || true
			fi
			;;
		*)
			return 1
			;;
	esac
}

handle_clear_logs() {
	local log_type site log_paths log_path cleared

	json_get_var log_type "type"
	json_get_var site "site"

	log_paths="$(resolve_log_paths "${log_type}" "${site}")" || {
		json_init
		json_add_string "error" "invalid log request"
		json_dump
		return
	}

	if [ -z "${log_paths}" ]; then
		json_init
		json_add_string "error" "log file not found"
		json_dump
		return
	fi

	cleared="0"
	for log_path in ${log_paths}; do
		[ -f "${log_path}" ] || continue
		printf '' > "${log_path}" || {
			json_init
			json_add_string "error" "failed to clear log file"
			json_add_string "path" "${log_path}"
			json_dump
			return
		}
		cleared="1"
	done

	if [ "${cleared}" != "1" ]; then
		json_init
		json_add_string "error" "log file not found"
		json_dump
		return
	fi

	json_init
	json_add_string "result" "ok"
	json_add_string "path" "${log_paths}"
	json_dump
}

