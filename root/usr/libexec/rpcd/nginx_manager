_list_cert() {
	local section="$1"
	local name type cert_path key_path domain auto_renew validation_method dns_api dns_wait acme_status acme_detail account_email

	name="$(uci -q get "nginx_manager.${section}.name")" || name="${section}"
	type="$(uci -q get "nginx_manager.${section}.type")" || type="manual"
	cert_path="$(uci -q get "nginx_manager.${section}.cert_path")" || cert_path=""
	key_path="$(uci -q get "nginx_manager.${section}.key_path")" || key_path=""
	domain="$(uci -q get "nginx_manager.${section}.domain")" || domain=""
	auto_renew="$(uci -q get "nginx_manager.${section}.auto_renew")" || auto_renew="0"
	validation_method="$(uci -q get "nginx_manager.${section}.validation_method")" || validation_method=""
	dns_api="$(uci -q get "nginx_manager.${section}.dns_api")" || dns_api=""
	dns_wait="$(uci -q get "nginx_manager.${section}.dns_wait")" || dns_wait=""
	acme_status="$(uci -q get "nginx_manager.${section}.acme_status")" || acme_status=""
	acme_detail="$(uci -q get "nginx_manager.${section}.acme_detail")" || acme_detail=""
	if [ "${type}" = "acme" ]; then
		account_email="$(uci -q get "acme.acme.account_email")" || account_email=""
	fi

	json_add_object ""
	json_add_string "id" "${section}"
	json_add_string "name" "${name}"
	json_add_string "type" "${type}"
	json_add_string "cert_path" "${cert_path}"
	json_add_string "key_path" "${key_path}"
	json_add_string "domain" "${domain}"
	json_add_string "auto_renew" "${auto_renew}"
	[ -n "${validation_method}" ] && json_add_string "validation_method" "${validation_method}"
	[ -n "${dns_api}" ] && json_add_string "dns_api" "${dns_api}"
	[ -n "${dns_wait}" ] && json_add_string "dns_wait" "${dns_wait}"
	[ -n "${acme_status}" ] && json_add_string "acme_status" "${acme_status}"
	[ -n "${acme_detail}" ] && json_add_string "acme_detail" "${acme_detail}"
	[ -n "${account_email}" ] && json_add_string "account_email" "${account_email}"

	# Return masked credential keys for editing (values hidden for security)
	if [ "${type}" = "acme" ] && [ "${validation_method}" = "dns" ] && uci -q get "acme.${section}" >/dev/null 2>&1; then
		local cred_keys=""
		local cred_line
		uci -q get "acme.${section}.credentials" | while IFS= read -r cred_line; do
			[ -z "${cred_line}" ] && continue
			local key_name
			key_name="$(printf '%s' "${cred_line}" | sed -n 's/^\([A-Za-z_][A-Za-z0-9_]*\)=.*/\1/p')"
			[ -n "${key_name}" ] && echo "${key_name}"
		done | tr '\n' ',' | sed 's/,$//' > /tmp/_nm_cred_keys_$$
		cred_keys="$(cat /tmp/_nm_cred_keys_$$ 2>/dev/null)"
		rm -f /tmp/_nm_cred_keys_$$
		[ -n "${cred_keys}" ] && json_add_string "credential_keys" "${cred_keys}"
	fi

	local status="valid"
	if [ "${type}" = "acme" ] && [ "${acme_status}" = "running" ]; then
		status="acme_running"
	elif [ "${type}" = "acme" ] && [ "${acme_status}" = "failed" ]; then
		status="acme_failed"
	elif [ -n "${cert_path}" ] && [ ! -f "${cert_path}" ]; then
		status="missing"
	elif [ -n "${cert_path}" ] && [ -f "${cert_path}" ]; then
		local days
		days="$(get_cert_expiry "${cert_path}")" || days="-1"
		if [ "${days}" -lt 0 ]; then
			status="expired"
		elif [ "${days}" -lt 30 ]; then
			status="expiring"
		fi
	fi
	json_add_string "status" "${status}"

	json_close_object
}

