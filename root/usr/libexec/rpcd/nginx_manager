handle_set_file_dangerous() {
	local file_path content
	json_get_var file_path "path"
	json_get_var content "content"

	[ -z "${file_path}" ] && { json_init; json_add_string "error" "missing path"; json_dump; return; }
	[ -z "${content}" ] && { json_init; json_add_string "error" "missing content"; json_dump; return; }

	local dangerous
	dangerous="$(uci -q get nginx_manager.global.dangerous_core_edit)" || dangerous="0"
	[ "${dangerous}" = "1" ] || {
		json_init
		json_add_string "error" "dangerous_core_edit not enabled"
		json_dump
		return
	}

	case "${file_path}" in
		/etc/nginx/uci.conf.template|/etc/nginx/nginx.conf)
			;;
		/etc/nginx/conf.d/luci-manager/*)
			;;
		*)
			json_init
			json_add_string "error" "path not allowed"
			json_dump
			return
			;;
	esac

	load_global_config
	detect_nginx_conf
	local timestamp
	timestamp="$(date '+%Y-%m-%d-%H%M%S')"
	local backup_path="${BACKUP_DIR}/${timestamp}"
	mkdir -p "${backup_path}/nginx"
	[ -d /etc/nginx ] && cp -a /etc/nginx/* "${backup_path}/nginx/" 2>/dev/null
	[ -f /etc/config/nginx ] && cp -a /etc/config/nginx "${backup_path}/config-nginx"
	[ -f "${NGINX_MANAGER_CONFIG}" ] && cp -a "${NGINX_MANAGER_CONFIG}" "${backup_path}/config-nginx-manager"

	printf '%s' "${content}" > "${file_path}"

	local test_output
	test_output="$(nginx -t -c "${NGINX_CONF_PATH}" 2>&1)"
	if [ $? -ne 0 ]; then
		local backup_file="${backup_path}/nginx/${file_path#/etc/nginx/}"
		if [ -f "${backup_file}" ]; then
			cp "${backup_file}" "${file_path}"
		fi
		nginx -t -c "${NGINX_CONF_PATH}" >/dev/null 2>&1
		/etc/init.d/nginx reload >/dev/null 2>&1

		json_init
		json_add_string "error" "nginx -t failed after write"
		json_add_string "detail" "${test_output}"
		json_add_string "rolled_back" "1"
		json_dump
		return
	fi

	/etc/init.d/nginx reload >/dev/null 2>&1

	json_init
	json_add_string "result" "ok"
	json_dump
}

handle_list_backups() {
	load_global_config

	json_init
	json_add_string "max_backups" "$(get_max_backups)"
	json_add_array "backups"

	for backup_dir in "${BACKUP_DIR}"/20*; do
		[ -d "${backup_dir}" ] || continue
		local backup_name
		backup_name="$(basename "${backup_dir}")"

		json_add_object ""
		json_add_string "id" "${backup_name}"
		json_add_string "timestamp" "${backup_name}"

		if [ -f "${backup_dir}/manifest.json" ]; then
			local source
			source="$(jsonfilter -i "${backup_dir}/manifest.json" -e '@.source' 2>/dev/null)" || source="unknown"
			json_add_string "source" "${source}"
		fi

		json_close_object
	done

	json_close_array
	json_dump
}

cleanup_old_backups() {
	local max_backups count prune_count

	load_global_config
	max_backups="$(get_max_backups)"
	count="$(ls -1d "${BACKUP_DIR}"/20* 2>/dev/null | wc -l)"
	[ "${count}" -gt "${max_backups}" ] || return 0

	prune_count=$((count - max_backups))
	ls -1d "${BACKUP_DIR}"/20* 2>/dev/null | head -n "${prune_count}" | while read -r old_backup; do
		rm -rf "${old_backup}"
	done
}

handle_get_backup_settings() {
