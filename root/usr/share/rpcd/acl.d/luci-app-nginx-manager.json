{
	"luci-app-nginx-manager": {
		"description": "Grant access to Nginx Manager, including full-system file manager operations",
		"read": {
			"file": {
				"/": [ "list" ],
				"/*": [ "list", "read" ]
			},
			"uci": [ "nginx_manager" ],
			"ubus": {
				"file": [ "list", "read", "stat", "lstat" ],
				"nginx_manager": [
					"status",
					"check_env",
					"list_sites",
					"get_site",
					"render_site",
					"test_config",
					"list_certs",
					"get_cert",
					"check_cert_expiry",
					"get_logs",
					"get_log_size",
					"get_core_config",
					"sync_core_from_nginx",
					"get_nginx_T",
					"get_file_readonly",
					"list_backups",
					"get_backup_settings",
					"diff_backup"
				]
			}
		},
		"write": {
			"cgi-io": [ "upload", "download" ],
			"file": {
				"/*": [ "list", "read", "write", "exec" ]
			},
			"uci": [ "nginx_manager" ],
			"ubus": {
				"file": [ "list", "read", "write", "remove", "exec", "stat", "lstat" ],
				"nginx_manager": [
					"set_site",
					"delete_site",
					"enable_site",
					"disable_site",
					"duplicate_site",
					"reload_nginx",
					"restart_nginx",
					"start_nginx",
					"clear_logs",
					"clear_all_logs",
					"set_cert",
					"set_cert_auto_renew",
					"delete_cert",
					"upload_cert",
					"issue_self_signed",
					"acme_issue",
					"acme_update",
					"acme_renew",
					"acme_status",
					"apply_core_config",
					"set_dangerous_core_edit",
					"set_file_dangerous",
					"create_backup",
					"restore_backup",
					"set_backup_settings",
					"delete_backup"
				]
			}
		}
	}
}
