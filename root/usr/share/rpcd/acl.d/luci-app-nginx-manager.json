			"uci": [ "nginx_manager" ],
			"ubus": {
				"nginx_manager": [
					"status",
					"check_env",
					"list_sites",
					"get_site",
					"render_site",
					"test_config",
					"list_certs",
					"get_cert",
					"check_cert_expiry",
					"get_logs",
					"get_core_config",
					"sync_core_from_nginx",
