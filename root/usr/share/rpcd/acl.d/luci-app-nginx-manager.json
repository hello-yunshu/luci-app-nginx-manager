			"ubus": {
				"nginx_manager": [
					"set_site",
					"delete_site",
					"enable_site",
					"disable_site",
					"reload_nginx",
					"restart_nginx",
					"start_nginx",
					"clear_logs",
					"set_cert",
					"delete_cert",
					"upload_cert",
					"issue_self_signed",
					"acme_issue",
					"acme_renew",
					"acme_status",
					"set_core_config_safe",
					"apply_core_config",
					"set_dangerous_core_edit",
					"set_file_dangerous",
					"create_backup",
					"restore_backup",
					"set_backup_settings",
					"delete_backup"
				]
			}
		}
	}
}
